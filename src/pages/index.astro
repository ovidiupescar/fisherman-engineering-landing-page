---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Fisherman Engineering">
    <div class="relative min-h-screen flex flex-col">
        <!-- Navigation -->
        <nav class="border-b border-white/10 backdrop-blur-md sticky top-0 z-50 bg-[#0a0a0a]/80">
            <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
                <a href="/" class="text-xl font-bold tracking-tight text-white flex items-center gap-2">
                    <span class="text-primary font-mono">///</span> Fisherman Engineering
                </a>
                <a href="mailto:ovidiupescar@fishermanengineering.com" class="text-sm font-medium text-gray-400 hover:text-white transition-colors border border-white/10 px-4 py-2 rounded-md hover:bg-white/5">
                    Contact
                </a>
            </div>
        </nav>

        <main class="flex-grow">
            <!-- Hero Section -->
            <section class="relative pt-32 pb-20 px-6 border-b border-white/10 overflow-hidden">
                <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]"></div>
                
                <div class="max-w-4xl mx-auto relative z-10">
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-mono text-primary mb-8">
                        <span>EST. 2017</span>
                    </div>
                    <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 leading-tight">
                        Software Engineering <br />
                        <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-white/50">Services.</span>
                    </h1>
                    <p class="text-xl text-gray-400 max-w-2xl mb-10 leading-relaxed">
                        Specialized in C/C++ Embedded Development, AUTOSAR Integration, and ISO 26262 Safety Analysis for the automotive industry.
                    </p>
                    
                    <div class="flex flex-wrap gap-4">
                        <a href="mailto:ovidiupescar@fishermanengineering.com" class="px-8 py-3 bg-primary text-white font-semibold rounded hover:bg-primary/90 transition-colors inline-flex items-center gap-2">
                            Get in touch <span class="font-mono">-></span>
                        </a>
                    </div>
                </div>
            </section>

            <!-- Features Grid -->
            <section class="py-24 px-6 relative">
                 <div class="max-w-7xl mx-auto">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                        <!-- Card 1 -->
                        <div class="p-8 rounded-xl bg-white/5 border border-white/10 hover:border-primary/50 transition-colors group">
                            <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-6 group-hover:scale-110 transition-transform">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                                </svg>
                            </div>
                            <h3 class="text-xl font-bold mb-4 font-mono">Software Development</h3>
                            <ul class="space-y-3 text-gray-400">
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary/50"></span>
                                    C/C++ Embedded
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary/50"></span>
                                    AUTOSAR Integration
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary/50"></span>
                                    Software Architecture
                                </li>
                            </ul>
                        </div>

                        <!-- Card 2 -->
                        <div class="p-8 rounded-xl bg-white/5 border border-white/10 hover:border-primary/50 transition-colors group">
                             <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-6 group-hover:scale-110 transition-transform">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <h3 class="text-xl font-bold mb-4 font-mono">ISO 26262 Safety</h3>
                            <ul class="space-y-3 text-gray-400">
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary/50"></span>
                                    FMEA / FTA / SFA
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary/50"></span>
                                    Safety Architecture
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary/50"></span>
                                    Safety Requirements
                                </li>
                            </ul>
                        </div>

                        <!-- Card 3 -->
                        <div class="p-8 rounded-xl bg-white/5 border border-white/10 hover:border-primary/50 transition-colors group">
                             <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-6 group-hover:scale-110 transition-transform">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283-.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                                </svg>
                            </div>
                            <h3 class="text-xl font-bold mb-4 font-mono">Project Management</h3>
                            <ul class="space-y-3 text-gray-400">
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary/50"></span>
                                    Team Leading
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary/50"></span>
                                    Project Monitoring
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary/50"></span>
                                    Stakeholder Satisfaction
                                </li>
                            </ul>
                        </div>

                        <!-- Card 4 -->
                        <div class="p-8 rounded-xl bg-white/5 border border-white/10 hover:border-primary/50 transition-colors group">
                             <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-6 group-hover:scale-110 transition-transform">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
                                </svg>
                            </div>
                            <h3 class="text-xl font-bold mb-4 font-mono">ISO 42001 AI Management</h3>
                            <ul class="space-y-3 text-gray-400">
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary/50"></span>
                                    AI Management Systems
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary/50"></span>
                                    AI Governance
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary/50"></span>
                                    AI Risk Management
                                </li>
                            </ul>
                        </div>

                        <!-- Card 5 -->
                        <div class="p-8 rounded-xl bg-white/5 border border-white/10 hover:border-primary/50 transition-colors group">
                             <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-6 group-hover:scale-110 transition-transform">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                </svg>
                            </div>
                            <h3 class="text-xl font-bold mb-4 font-mono">Robotics Safety</h3>
                            <ul class="space-y-3 text-gray-400">
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary/50"></span>
                                    Functional Safety
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary/50"></span>
                                    Collaborative Robots
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary/50"></span>
                                    Risk Assessment
                                </li>
                            </ul>
                        </div>
                    </div>
                 </div>
            </section>

            <!-- Open Source Section -->
            <section class="py-24 px-6 border-t border-white/10">
                <div class="max-w-7xl mx-auto">
                    <div class="text-xs font-mono text-primary mb-3">// OPEN SOURCE</div>
                    <div class="p-8 md:p-10 rounded-xl bg-white/5 border border-white/10 hover:border-primary/50 transition-colors">
                        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
                            <div class="max-w-2xl">
                                <div class="flex items-center gap-3 mb-4">
                                    <h3 class="text-2xl font-bold font-mono">Human-Robot Interface</h3>
                                    <span class="px-2 py-0.5 rounded-full bg-primary/10 border border-primary/20 text-xs font-mono text-primary">HRI</span>
                                </div>
                                <p class="text-gray-400 leading-relaxed mb-6">
                                    An open-source robotics stack for building a bilingual voice companion: ESP32-S3 face
                                    firmware, a Jetson-side ROS 2 pipeline for audio, perception and control, and an
                                    agent-platform adapter for extensible skills. Designed to run offline-capable on edge
                                    hardware.
                                </p>
                                <div class="flex flex-wrap gap-2 text-xs font-mono text-gray-400">
                                    <span class="px-3 py-1 rounded-full bg-white/5 border border-white/10">ROS 2</span>
                                    <span class="px-3 py-1 rounded-full bg-white/5 border border-white/10">Jetson Orin</span>
                                    <span class="px-3 py-1 rounded-full bg-white/5 border border-white/10">ESP32-S3</span>
                                    <span class="px-3 py-1 rounded-full bg-white/5 border border-white/10">Python / C++</span>
                                </div>
                            </div>
                            <a href="https://github.com/ovidiupescar/human-robot-interface" target="_blank" rel="noopener noreferrer" class="shrink-0 px-6 py-3 bg-white/5 border border-white/10 text-white font-semibold rounded hover:border-primary/50 hover:bg-white/10 transition-colors inline-flex items-center gap-2">
                                View on GitHub <span class="font-mono">-></span>
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Footer -->
            <footer class="py-12 px-6 border-t border-white/10">
                <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
                    <div class="text-gray-500 text-sm">
                        &copy; {new Date().getFullYear()} Fisherman Engineering.
                    </div>
                    <div class="text-gray-500 text-sm">
                        <a href="mailto:ovidiupescar@fishermanengineering.com" class="hover:text-primary transition-colors">
                            ovidiupescar@fishermanengineering.com
                        </a>
                    </div>
                </div>
            </footer>
        </main>
    </div>
</Layout>
