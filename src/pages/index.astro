---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Fisherman Engineering — Automotive Safety, Robotics Safety & Systems Consulting">
    <div class="relative min-h-screen flex flex-col">
        <!-- Navigation -->
        <nav class="border-b border-border-mist sticky top-0 z-50 bg-offwhite/85 backdrop-blur-md">
            <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
                <a href="/" class="flex items-center" aria-label="Fisherman Engineering home">
                    <img src="/fe-wordmark.png" alt="Fisherman Engineering" class="h-6 w-auto" />
                </a>
                <div class="flex items-center gap-8">
                    <div class="hidden md:flex items-center gap-8 text-sm font-medium text-steel">
                        <a href="#services" class="hover:text-navy transition-colors">Services</a>
                        <a href="#open-source" class="hover:text-navy transition-colors">Open Source</a>
                    </div>
                    <a href="mailto:ovidiupescar@fishermanengineering.com" class="text-sm font-semibold text-white bg-orange px-4 py-2 rounded-md hover:bg-orange/90 transition-colors">
                        Get in Touch
                    </a>
                </div>
            </div>
        </nav>

        <main class="flex-grow">
            <!-- Hero Section -->
            <section class="relative bg-midnight overflow-hidden">
                <!-- technical grid motif -->
                <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff0a_1px,transparent_1px),linear-gradient(to_bottom,#ffffff0a_1px,transparent_1px)] bg-[size:48px_48px]"></div>
                <!-- signal halo glow, top-right -->
                <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-orange/20 blur-[120px]"></div>

                <div class="relative z-10 max-w-7xl mx-auto px-6 pt-28 pb-28 flex items-center gap-16">
                    <div class="max-w-3xl flex-1">
                        <div class="flex items-center gap-3 mb-8">
                            <span class="px-3 py-1 rounded-full border border-white/15 text-white/70 font-mono text-xs">EST. 2017</span>
                            <span class="flex items-center gap-2 font-mono text-xs uppercase tracking-wider text-orange">
                                <span class="w-1.5 h-1.5 rounded-full bg-orange"></span>
                                Automotive · Robotics · Systems
                            </span>
                        </div>

                        <h1 class="font-heading font-bold text-white text-4xl sm:text-5xl md:text-6xl tracking-tight leading-[1.05] mb-6">
                            Engineering Safety for<br />
                            <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-white/55">Automotive, AI &amp; Robotics.</span>
                        </h1>

                        <div class="w-16 h-1 rounded-full bg-orange mb-8"></div>

                        <p class="text-lg md:text-xl text-tech/80 max-w-2xl mb-10 leading-relaxed">
                            Specialized in functional safety analysis, embedded C/C++ software, and AI management systems — across automotive, robotics, and autonomous machines.
                        </p>

                        <div class="flex flex-wrap gap-4">
                            <a href="mailto:ovidiupescar@fishermanengineering.com" class="px-7 py-3 bg-orange text-white font-semibold rounded-md hover:bg-orange/90 transition-colors inline-flex items-center gap-2">
                                Get in Touch <span class="font-mono">-></span>
                            </a>
                            <a href="#services" class="px-7 py-3 border border-white/20 text-white font-semibold rounded-md hover:bg-white/5 transition-colors">
                                View Services
                            </a>
                        </div>
                    </div>

                    <!-- FE Signal Halo brand tile -->
                    <div class="hidden lg:flex shrink-0 items-center justify-center w-72 h-72 rounded-2xl bg-cool-white border border-white/10 shadow-2xl shadow-black/40">
                        <img src="/fe-icon.png" alt="Fisherman Engineering FE Signal Halo mark" class="w-44 h-44" />
                    </div>
                </div>
            </section>

            <!-- Services Grid -->
            <section id="services" class="py-24 px-6 bg-offwhite">
                 <div class="max-w-7xl mx-auto">
                    <div class="mb-14 max-w-2xl">
                        <div class="font-mono text-xs uppercase tracking-wider text-orange mb-3">// Services</div>
                        <h2 class="font-heading font-semibold text-navy text-3xl md:text-4xl tracking-tight">
                            Safety-critical engineering, end to end.
                        </h2>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        <!-- Card 1 -->
                        <div class="group p-8 rounded-lg bg-white border border-border-mist hover:border-orange/60 hover:shadow-xl hover:shadow-navy/5 transition-all">
                            <div class="w-12 h-12 rounded-md bg-tech flex items-center justify-center text-navy mb-6 group-hover:bg-orange/10 group-hover:text-orange transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                                </svg>
                            </div>
                            <span class="block w-8 h-0.5 rounded-full bg-orange mb-4"></span>
                            <h3 class="text-xl font-heading font-semibold text-navy mb-4">Software Development</h3>
                            <ul class="space-y-3 text-steel">
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-orange"></span>
                                    C/C++ Embedded
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-orange"></span>
                                    Python
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-orange"></span>
                                    ROS 2
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-orange"></span>
                                    Software Architecture
                                </li>
                            </ul>
                        </div>

                        <!-- Card 2 -->
                        <div class="group p-8 rounded-lg bg-white border border-border-mist hover:border-orange/60 hover:shadow-xl hover:shadow-navy/5 transition-all">
                            <div class="w-12 h-12 rounded-md bg-tech flex items-center justify-center text-navy mb-6 group-hover:bg-orange/10 group-hover:text-orange transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <span class="block w-8 h-0.5 rounded-full bg-orange mb-4"></span>
                            <h3 class="text-xl font-heading font-semibold text-navy mb-4">ISO 26262 Safety</h3>
                            <ul class="space-y-3 text-steel">
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-orange"></span>
                                    FMEA / FTA / SFA
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-orange"></span>
                                    Safety Architecture
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-orange"></span>
                                    Safety Requirements
                                </li>
                            </ul>
                        </div>

                        <!-- Card 3 -->
                        <div class="group p-8 rounded-lg bg-white border border-border-mist hover:border-orange/60 hover:shadow-xl hover:shadow-navy/5 transition-all">
                            <div class="w-12 h-12 rounded-md bg-tech flex items-center justify-center text-navy mb-6 group-hover:bg-orange/10 group-hover:text-orange transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283-.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                                </svg>
                            </div>
                            <span class="block w-8 h-0.5 rounded-full bg-orange mb-4"></span>
                            <h3 class="text-xl font-heading font-semibold text-navy mb-4">Project Management</h3>
                            <ul class="space-y-3 text-steel">
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-orange"></span>
                                    Team Leading
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-orange"></span>
                                    Project Monitoring
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-orange"></span>
                                    Stakeholder Satisfaction
                                </li>
                            </ul>
                        </div>

                        <!-- Card 4 -->
                        <div class="group p-8 rounded-lg bg-white border border-border-mist hover:border-orange/60 hover:shadow-xl hover:shadow-navy/5 transition-all">
                            <div class="w-12 h-12 rounded-md bg-tech flex items-center justify-center text-navy mb-6 group-hover:bg-orange/10 group-hover:text-orange transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
                                </svg>
                            </div>
                            <span class="block w-8 h-0.5 rounded-full bg-orange mb-4"></span>
                            <h3 class="text-xl font-heading font-semibold text-navy mb-4">ISO 42001 AI Management</h3>
                            <ul class="space-y-3 text-steel">
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-orange"></span>
                                    AI Management Systems
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-orange"></span>
                                    AI Governance
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-orange"></span>
                                    AI Risk Management
                                </li>
                            </ul>
                        </div>

                        <!-- Card 5 -->
                        <div class="group p-8 rounded-lg bg-white border border-border-mist hover:border-orange/60 hover:shadow-xl hover:shadow-navy/5 transition-all">
                            <div class="w-12 h-12 rounded-md bg-tech flex items-center justify-center text-navy mb-6 group-hover:bg-orange/10 group-hover:text-orange transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                </svg>
                            </div>
                            <span class="block w-8 h-0.5 rounded-full bg-orange mb-4"></span>
                            <h3 class="text-xl font-heading font-semibold text-navy mb-4">Robotics Safety</h3>
                            <ul class="space-y-3 text-steel">
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-orange"></span>
                                    Functional Safety
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-orange"></span>
                                    Collaborative Robots
                                </li>
                                <li class="flex items-center gap-3">
                                    <span class="w-1.5 h-1.5 rounded-full bg-orange"></span>
                                    Risk Assessment
                                </li>
                            </ul>
                        </div>
                    </div>
                 </div>
            </section>

            <!-- Open Source Section -->
            <section id="open-source" class="pb-24 px-6 bg-offwhite">
                <div class="max-w-7xl mx-auto">
                    <div class="relative overflow-hidden p-8 md:p-12 rounded-xl bg-midnight">
                        <div class="absolute -top-20 -right-20 w-72 h-72 rounded-full bg-orange/15 blur-[100px]"></div>
                        <div class="relative z-10 flex flex-col md:flex-row md:items-start md:justify-between gap-8">
                            <div class="max-w-2xl">
                                <div class="font-mono text-xs uppercase tracking-wider text-orange mb-4">// Open Source</div>
                                <div class="flex items-center gap-3 mb-4">
                                    <h3 class="text-2xl md:text-3xl font-heading font-semibold text-white">Human-Robot Interface</h3>
                                    <span class="px-2 py-0.5 rounded-full bg-orange/15 border border-orange/30 text-xs font-mono text-orange">HRI</span>
                                </div>
                                <p class="text-tech/75 leading-relaxed mb-6">
                                    An open-source robotics stack for building a bilingual voice companion: ESP32-S3 face
                                    firmware, a Jetson-side ROS 2 pipeline for audio, perception and control, and an
                                    agent-platform adapter for extensible skills. Designed to run offline-capable on edge
                                    hardware.
                                </p>
                                <div class="flex flex-wrap gap-2 text-xs font-mono text-tech/70">
                                    <span class="px-3 py-1 rounded-full bg-white/5 border border-white/10">ROS 2</span>
                                    <span class="px-3 py-1 rounded-full bg-white/5 border border-white/10">Jetson Orin</span>
                                    <span class="px-3 py-1 rounded-full bg-white/5 border border-white/10">ESP32-S3</span>
                                    <span class="px-3 py-1 rounded-full bg-white/5 border border-white/10">Python / C++</span>
                                </div>
                            </div>
                            <a href="https://github.com/ovidiupescar/human-robot-interface" target="_blank" rel="noopener noreferrer" class="shrink-0 px-6 py-3 bg-orange text-white font-semibold rounded-md hover:bg-orange/90 transition-colors inline-flex items-center gap-2">
                                View on GitHub <span class="font-mono">-></span>
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Footer -->
            <footer class="bg-navy py-14 px-6">
                <div class="max-w-7xl mx-auto">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
                        <div>
                            <img src="/fe-wordmark.png" alt="Fisherman Engineering" class="h-6 w-auto brightness-0 invert opacity-90 mb-3" />
                            <p class="text-tech/55 text-sm font-mono">Automotive Safety · Robotics Safety · Systems Consulting</p>
                        </div>
                        <a href="mailto:ovidiupescar@fishermanengineering.com" class="text-tech/70 text-sm hover:text-orange transition-colors">
                            ovidiupescar@fishermanengineering.com
                        </a>
                    </div>
                    <div class="mt-10 pt-6 border-t border-white/10 text-tech/45 text-sm">
                        &copy; {new Date().getFullYear()} Fisherman Engineering SRL.
                    </div>
                </div>
            </footer>
        </main>
    </div>
</Layout>
